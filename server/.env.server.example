# ── Server ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── Redis / Upstash ────────────────────────────────────────────────
# Option A — Upstash (recommended, free tier at upstash.com):
#   1. Create a Redis database at upstash.com
#   2. Copy the "REST URL" → use the rediss:// connection string
# REDIS_URL=rediss://default:YOUR_TOKEN@YOUR_HOST.upstash.io:6380
#
# Option B — Local Docker Redis (from docker-compose):
# REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379
#
# Leave blank to run without Redis (app still works, no token blacklisting)
REDIS_URL=

# ── Redis password (docker-compose local Redis only) ──────────────
# Used by docker-compose.yml to set --requirepass on the Redis container.
# Must match the password in your REDIS_URL above when using local Docker Redis.
# Generate a strong random value: openssl rand -hex 32
REDIS_PASSWORD=change_this_to_a_strong_random_redis_password

# ── MongoDB Atlas ──────────────────────────────────────────────────
# Get this from: Atlas → Connect → Drivers → Node.js
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/bookfilm?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_minimum_32_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_also_long_and_random
JWT_EXPIRY=15m
REFRESH_EXPIRY=7d

# ── AWS S3 ───────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=bookfilm-assets

# ── SMTP (optional — for invite emails & password reset) ─────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@bookfilm.studio

# ── Admin ────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com

# ── MongoDB Docker password (for docker-compose) ─────────────────
MONGO_PASSWORD=changeme

# ── Managed generation (platform-held provider keys; 1B+) ────────
GROQ_API_KEY=
ANTHROPIC_API_KEY=
REPLICATE_API_TOKEN=
FALAI_KEY=
OPENAI_API_KEY=
ELEVENLABS_KEY=

# ── Managed generation guardrails (1C/1D) ───────────────────────
MANAGED_GENERATION_ENABLED=true
MANAGED_MAX_CONCURRENT=3
MANAGED_CAP_TEXT_DAILY=20
MANAGED_CAP_IMAGE_DAILY=50
MANAGED_CAP_VOICE_DAILY=100

# ── Billing (Stripe — #4) ────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PRO=
STRIPE_PRICE_STUDIO=
STRIPE_PRICE_PACK_SMALL=
STRIPE_PRICE_PACK_MEDIUM=
STRIPE_PRICE_PACK_LARGE=

# ── Social distribution (#7) — connect + schedule posts to platforms ──
# Required to enable any social posting:
#   SOCIAL_TOKEN_KEY      — a long random secret; encrypts stored OAuth tokens at rest (AES-256-GCM). REQUIRED for social.
#   SOCIAL_REDIRECT_BASE  — public base URL the OAuth callbacks return to (defaults to the request host / CLIENT_URL).
#                           Each platform's OAuth app must whitelist <base>/api/social/<platform>/callback as a redirect URI.
SOCIAL_TOKEN_KEY=
SOCIAL_REDIRECT_BASE=
#
# Per-platform OAuth app credentials. A platform stays "Setup required" (no live posting) until its creds are filled.
# Register a developer app on each platform, then paste its client id/secret here:
#   YouTube  → Google Cloud Console (OAuth client; enable YouTube Data API v3)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
#   TikTok   → TikTok for Developers (Content Posting API; app review required)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
#   Instagram + Facebook → Meta for Developers app (shared App ID/Secret; IG needs a Business account linked to a Page)
META_APP_ID=
META_APP_SECRET=
#   X (Twitter) → X Developer Portal (OAuth2; media posting needs a paid API tier). X_* preferred, TWITTER_* accepted.
X_CLIENT_ID=
X_CLIENT_SECRET=
#   LinkedIn → LinkedIn Developers app (w_member_social; Community/Marketing API approval)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Error tracking (optional) ─────────────────────────────────────
# Set SENTRY_DSN to enable Sentry error tracking in the server and worker.
# Leave blank (or unset) to disable — the app boots fine without it.
# Get your DSN from: https://sentry.io → Project Settings → Client Keys
SENTRY_DSN=https://7e7a1f4444efff3f337524d1fa28c21b@o4506923213455360.ingest.us.sentry.io/4506923262148608
