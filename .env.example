# ── Frontend (Vite) ──────────────────────────────────────────────
# API base URL the SPA calls. REQUIRED at build time for any non-local deploy
# (the production build fails if this is unset in production mode).
VITE_API_URL=http://localhost:3001
# Login is always required now; this flag is legacy.
VITE_USE_AUTH=true

# ── docker-compose interpolation (root .env is read by docker compose) ──
# REDIS_PASSWORD MUST match the password embedded in REDIS_URL in server/.env.server
# (e.g. REDIS_URL=redis://:<REDIS_PASSWORD>@localhost:6379). If unset, the redis
# container fails fast with a clear message instead of crash-looping.
REDIS_PASSWORD=changeme
# Mongo password for the local docker-compose mongo (unused when MONGODB_URI points at Atlas).
MONGO_PASSWORD=changeme
